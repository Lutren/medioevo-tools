{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.seto.observation-envelope.v1",
  "title": "SETO ObservationEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_version",
    "source_path",
    "source_kind",
    "evidence",
    "psi_state",
    "claim_level",
    "falsifiers",
    "risk_flags",
    "action_gate",
    "decision",
    "fingerprint"
  ],
  "properties": {
    "envelope_version": {
      "const": "seto-observation-v1"
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "file",
        "directory",
        "zip",
        "repo",
        "generated_artifact",
        "external_note",
        "coordination_contract",
        "handoff_contract",
        "topic_event"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "psi_state": {
      "type": "string",
      "enum": [
        "CERTEZA",
        "INFERENCIA",
        "INCOGNITA",
        "BLOQUEADO"
      ]
    },
    "claim_level": {
      "type": "string",
      "enum": [
        "operational",
        "research_only",
        "demo_only",
        "blocked_claim"
      ]
    },
    "falsifiers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "action_gate": {
      "type": "string",
      "enum": [
        "APPROVE",
        "REVIEW",
        "BLOCK"
      ]
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "fingerprint": {
      "type": "string",
      "minLength": 1
    }
  }
}
