{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medioevo.local/schemas/obsai/observation_envelope.v2.1.schema.json",
  "title": "ObservationEnvelope v2.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agent",
    "task",
    "timestamp",
    "claims",
    "R_or",
    "phi_moi",
    "gate",
    "regime",
    "evidence",
    "falsifier",
    "next_action",
    "calibration"
  ],
  "properties": {
    "schemaVersion": {
      "const": "obsai.observation_envelope.v2.1"
    },
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claimResult"
      }
    },
    "R_or": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "phi_moi": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "gate": {
      "enum": ["APPROVE", "REVIEW", "BLOCK"]
    },
    "regime": {
      "enum": ["EXPAND", "COMPRESS", "HOLD", "BLOCK"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "falsifier": {
      "type": ["string", "null"]
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "calibration": {
      "const": "DEMO_ONLY"
    }
  },
  "$defs": {
    "claimResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text",
        "label",
        "clarity",
        "R_components",
        "R_or",
        "phi_moi",
        "gate",
        "gate_contract",
        "falsifier_hint",
        "rewrite_hint",
        "science_gate_triggered",
        "warnings"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "enum": ["CERTEZA", "INFERENCIA", "INCOGNITA", "BLOQUEO"]
        },
        "clarity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "R_components": {
          "type": "object",
          "additionalProperties": false,
          "required": ["r_src", "r_def", "r_tst", "r_bnd"],
          "properties": {
            "r_src": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "r_def": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "r_tst": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "r_bnd": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "R_or": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "phi_moi": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "gate": {
          "enum": ["APPROVE", "REVIEW", "BLOCK"]
        },
        "gate_contract": {
          "$ref": "#/$defs/claimGateContract"
        },
        "falsifier_hint": {
          "type": ["string", "null"]
        },
        "rewrite_hint": {
          "type": ["string", "null"]
        },
        "science_gate_triggered": {
          "type": "boolean"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "claimGateContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "gates",
        "final_decision",
        "calibration"
      ],
      "properties": {
        "schemaVersion": {
          "const": "obsai.claim_gate_contract.v1"
        },
        "gates": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/gateOutcome"
          }
        },
        "final_decision": {
          "enum": ["APPROVE", "REVIEW", "BLOCK"]
        },
        "calibration": {
          "const": "DEMO_ONLY"
        }
      }
    },
    "gateOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "reason"],
      "properties": {
        "name": {
          "enum": ["TruthGate", "C-GATE", "PhysicsHonestyGate", "ScienceClaimGate"]
        },
        "status": {
          "enum": ["APPROVE", "REVIEW", "BLOCK"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
