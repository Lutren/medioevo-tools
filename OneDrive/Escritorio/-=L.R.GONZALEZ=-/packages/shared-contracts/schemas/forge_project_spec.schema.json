{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.forge_project_spec.v0.1",
  "title": "ForgeProjectSpec",
  "type": "object",
  "required": ["schema_version", "project_id", "source_system", "target_system", "integration_mode", "mutates_systems", "preview_contract", "public_safe", "action_gate", "boundary"],
  "properties": {
    "schema_version": { "const": "medioevo.forge_project_spec.v0.1" },
    "project_id": { "type": "string" },
    "source_system": { "enum": ["MEDIOEVO_FORGE_APP_GAME_CREATOR"] },
    "target_system": { "enum": ["DUAT_SIMULATOR_WORLD", "MEDIOEVO_SPACE_PUBLIC_PORTAL", "SHARED_CONTRACTS"] },
    "integration_mode": { "enum": ["contract_export", "preview_only", "direct_mutation"] },
    "mutates_systems": { "type": "array" },
    "preview_contract": { "type": "object" },
    "public_safe": { "type": "boolean" },
    "action_gate": { "type": "object" },
    "boundary": { "type": "object" }
  },
  "additionalProperties": false
}

