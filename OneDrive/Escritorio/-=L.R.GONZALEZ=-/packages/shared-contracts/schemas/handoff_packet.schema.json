{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.handoff_packet.v0.1",
  "title": "HandoffPacket",
  "type": "object",
  "required": ["schema_version", "handoff_id", "source_system", "destination_system", "public_safe", "summary", "artifacts", "next_action", "boundary"],
  "properties": {
    "schema_version": { "const": "medioevo.handoff_packet.v0.1" },
    "handoff_id": { "type": "string" },
    "source_system": { "enum": ["WABI_SABI_CONTROL_PLANE", "DUAT_SIMULATOR_WORLD", "MEDIOEVO_FORGE_APP_GAME_CREATOR", "MEDIOEVO_SPACE_PUBLIC_PORTAL", "SHARED_CONTRACTS"] },
    "destination_system": { "enum": ["WABI_SABI_CONTROL_PLANE", "DUAT_SIMULATOR_WORLD", "MEDIOEVO_FORGE_APP_GAME_CREATOR", "MEDIOEVO_SPACE_PUBLIC_PORTAL", "SHARED_CONTRACTS"] },
    "public_safe": { "type": "boolean" },
    "summary": { "type": "string" },
    "artifacts": { "type": "array" },
    "next_action": { "type": "string" },
    "boundary": { "type": "object" }
  },
  "additionalProperties": false
}

