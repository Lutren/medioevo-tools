{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.hypothesis_packet.v0.1",
  "title": "HypothesisPacket",
  "type": "object",
  "required": [
    "schema_version",
    "hypothesis_id",
    "source_system",
    "target_system",
    "claim",
    "counterclaim",
    "claim_level",
    "status",
    "falsifiers",
    "evidence_required",
    "evidence",
    "action_gate",
    "boundary"
  ],
  "properties": {
    "schema_version": { "const": "medioevo.hypothesis_packet.v0.1" },
    "hypothesis_id": { "type": "string" },
    "source_system": {
      "enum": [
        "WABI_SABI_CONTROL_PLANE",
        "DUAT_SIMULATOR_WORLD",
        "MEDIOEVO_FORGE_APP_GAME_CREATOR",
        "MEDIOEVO_SPACE_PUBLIC_PORTAL",
        "SHARED_CONTRACTS"
      ]
    },
    "target_system": {
      "enum": [
        "WABI_SABI_CONTROL_PLANE",
        "DUAT_SIMULATOR_WORLD",
        "MEDIOEVO_FORGE_APP_GAME_CREATOR",
        "MEDIOEVO_SPACE_PUBLIC_PORTAL",
        "SHARED_CONTRACTS"
      ]
    },
    "claim": { "type": "string" },
    "counterclaim": { "type": "string" },
    "claim_level": {
      "enum": [
        "operational",
        "research",
        "scientific",
        "public",
        "commercial",
        "public_scientific"
      ]
    },
    "status": { "enum": ["OPEN", "FALSIFIED", "SUPPORTED", "REVIEW", "BLOCK"] },
    "falsifiers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "evidence_required": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "counterexample_search": { "type": "object" },
    "grader": { "type": "object" },
    "action_gate": { "type": "object" },
    "boundary": { "type": "object" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
