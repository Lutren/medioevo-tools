{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.replay_frame.v0.1",
  "title": "ReplayFrame",
  "type": "object",
  "required": ["schema_version", "frame_id", "tick", "seed", "prev_hash", "state_delta", "event_refs", "replay_hash", "boundary"],
  "properties": {
    "schema_version": { "const": "medioevo.replay_frame.v0.1" },
    "frame_id": { "type": "string" },
    "tick": { "type": "integer" },
    "seed": { "type": "string" },
    "prev_hash": { "type": "string" },
    "state_delta": { "type": "object" },
    "event_refs": { "type": "array" },
    "replay_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "boundary": { "type": "object" }
  },
  "additionalProperties": false
}

