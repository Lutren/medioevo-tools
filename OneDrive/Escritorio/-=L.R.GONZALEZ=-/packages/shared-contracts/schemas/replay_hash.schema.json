{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.replay_hash.v0.1",
  "title": "ReplayHash",
  "type": "object",
  "required": ["schema_version", "seed", "prev_hash", "payload_hash", "hash"],
  "properties": {
    "schema_version": { "const": "medioevo.replay_hash.v0.1" },
    "seed": { "type": "string" },
    "prev_hash": { "type": "string" },
    "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}

