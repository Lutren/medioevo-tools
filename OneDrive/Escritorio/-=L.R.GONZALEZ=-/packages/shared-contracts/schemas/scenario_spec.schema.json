  "$id": "medioevo.scenario_spec.v0.1",
  "title": "ScenarioSpec",
  "type": "object",
  "required": ["schema_version", "scenario_id", "world_state_ref", "agent_refs", "initial_events", "director_constraints", "public_safe", "boundary"],
  "properties": {
    "schema_version": { "const": "medioevo.scenario_spec.v0.1" },
    "scenario_id": { "type": "string" },
    "world_state_ref": { "type": "string" },
    "agent_refs": { "type": "array", "minItems": 1 },
    "initial_events": { "type": "array" },
    "director_constraints": { "type": "object" },
    "public_safe": { "type": "boolean" },
    "boundary": { "type": "object" }
  },
  "additionalProperties": false
}

