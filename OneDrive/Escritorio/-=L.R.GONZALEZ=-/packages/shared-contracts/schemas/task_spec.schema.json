{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.task_spec.v0.1",
  "title": "TaskSpec",
  "type": "object",
  "required": ["schema_version", "task_id", "source_system", "target_system", "operation", "action_gate", "boundary"],
  "properties": {
    "schema_version": { "const": "medioevo.task_spec.v0.1" },
    "task_id": { "type": "string" },
    "source_system": { "enum": ["WABI_SABI_CONTROL_PLANE", "DUAT_SIMULATOR_WORLD", "MEDIOEVO_FORGE_APP_GAME_CREATOR", "MEDIOEVO_SPACE_PUBLIC_PORTAL", "SHARED_CONTRACTS"] },
    "target_system": { "enum": ["WABI_SABI_CONTROL_PLANE", "DUAT_SIMULATOR_WORLD", "MEDIOEVO_FORGE_APP_GAME_CREATOR", "MEDIOEVO_SPACE_PUBLIC_PORTAL", "SHARED_CONTRACTS"] },
    "operation": { "type": "object" },
    "inputs": { "type": "array" },
    "expected_outputs": { "type": "array" },
    "action_gate": { "type": "object" },
    "boundary": { "type": "object" }
  },
  "additionalProperties": false
}

