{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "medioevo.workpack.v0.1",
  "title": "Workpack",
  "type": "object",
  "required": ["schema_version", "workpack_id", "source_system", "tasks", "action_gate", "boundary"],
  "properties": {
    "schema_version": { "const": "medioevo.workpack.v0.1" },
    "workpack_id": { "type": "string" },
    "source_system": { "enum": ["WABI_SABI_CONTROL_PLANE", "DUAT_SIMULATOR_WORLD", "MEDIOEVO_FORGE_APP_GAME_CREATOR", "MEDIOEVO_SPACE_PUBLIC_PORTAL", "SHARED_CONTRACTS"] },
    "tasks": { "type": "array", "minItems": 1 },
    "operation": { "type": "object" },
    "action_gate": { "type": "object" },
    "boundary": { "type": "object" }
  },
  "additionalProperties": false
}

