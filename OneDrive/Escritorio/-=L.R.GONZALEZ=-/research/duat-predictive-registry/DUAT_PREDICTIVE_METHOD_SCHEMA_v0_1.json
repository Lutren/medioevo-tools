{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "duat.predictive_method.v0_1",
  "title": "DUAT Predictive Method v0.1",
  "type": "object",
  "required": [
    "method_id",
    "name",
    "type",
    "formula",
    "best_for",
    "failure_modes",
    "metrics_required",
    "osit_mapping",
    "integration_gate",
    "publication_gate"
  ],
  "properties": {
    "method_id": { "type": "string" },
    "name": { "type": "string" },
    "type": { "enum": ["filter", "model", "validator", "calibrator", "uncertainty", "ensemble", "causal_research"] },
    "formula": { "type": "string" },
    "best_for": { "type": "array", "items": { "type": "string" } },
    "failure_modes": { "type": "array", "items": { "type": "string" } },
    "metrics_required": { "type": "array", "items": { "type": "string" } },
    "osit_mapping": { "type": "string" },
    "integration_gate": { "enum": ["APPROVE", "REVIEW", "BLOCK"] },
    "publication_gate": { "const": "BLOCK" }
  },
  "additionalProperties": true
}
