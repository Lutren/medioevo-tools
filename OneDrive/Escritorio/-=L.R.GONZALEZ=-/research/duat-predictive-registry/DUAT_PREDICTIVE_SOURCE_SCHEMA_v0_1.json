{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "duat.predictive_source.v0_1",
  "title": "DUAT Predictive Source v0.1",
  "type": "object",
  "required": [
    "source_id",
    "name",
    "domain",
    "official_url",
    "api_docs_url",
    "access_type",
    "license_status",
    "rate_limit",
    "format",
    "frequency",
    "coverage_geo",
    "coverage_time",
    "predictive_value",
    "source_quality",
    "expected_r_reduction",
    "risks",
    "required_attribution",
    "osit_class",
    "integration_gate",
    "publication_gate"
  ],
  "properties": {
    "source_id": { "type": "string" },
    "name": { "type": "string" },
    "domain": { "type": "string" },
    "official_url": { "type": "string" },
    "api_docs_url": { "type": "string" },
    "access_type": { "enum": ["NO_KEY", "FREE_KEY", "BULK_DOWNLOAD", "SNAPSHOT", "REVIEW", "REVIEW_KEY_REQUIRED"] },
    "license_status": { "type": "string" },
    "rate_limit": { "type": "string" },
    "format": { "type": "array", "items": { "type": "string" } },
    "frequency": { "type": "string" },
    "coverage_geo": { "type": "string" },
    "coverage_time": { "type": "string" },
    "predictive_value": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_quality": { "type": "number", "minimum": 0, "maximum": 1 },
    "expected_r_reduction": { "type": "number", "minimum": 0, "maximum": 1 },
    "risks": { "type": "array", "items": { "type": "string" } },
    "required_attribution": { "type": "string" },
    "osit_class": { "enum": ["CERTEZA", "INFERENCIA", "INCOGNITA", "BLOQUEO"] },
    "integration_gate": { "enum": ["APPROVE", "REVIEW", "BLOCK", "REVIEW_KEY_REQUIRED", "REVIEW_LICENSE", "REVIEW_FORECAST_MARKET_SIGNAL"] },
    "publication_gate": { "const": "BLOCK" }
  },
  "additionalProperties": true
}
