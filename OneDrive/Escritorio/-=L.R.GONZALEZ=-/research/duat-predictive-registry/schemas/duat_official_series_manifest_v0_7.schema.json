{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "duat_official_series_manifest_v0_7.schema.json",
  "title": "DUAT Official Series Manifest v0.7",
  "type": "object",
  "required": ["version", "project", "series"],
  "properties": {
    "version": {
      "const": "0.7"
    },
    "project": {
      "const": "DUAT Predictive Registry"
    },
    "source_run_id": {
      "type": ["string", "null"]
    },
    "series": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "indicator_id",
          "source_name",
          "source_url",
          "license_terms",
          "frequency",
          "n_observations",
          "readiness_gate"
        ],
        "properties": {
          "indicator_id": {"type": "string"},
          "source_id": {"type": ["string", "null"]},
          "source_name": {"type": ["string", "null"]},
          "source_url": {"type": ["string", "null"]},
          "license_terms": {"type": ["string", "null"]},
          "license_review_required": {"type": "boolean"},
          "country_or_scope": {"type": ["string", "null"]},
          "frequency": {"type": ["string", "null"]},
          "start_year": {"type": ["integer", "null"]},
          "end_year": {"type": ["integer", "null"]},
          "n_observations": {"type": ["integer", "null"]},
          "unit": {"type": ["string", "null"]},
          "definition": {"type": ["string", "null"]},
          "download_method": {
            "enum": ["manual", "api", "fixture", "unknown"]
          },
          "raw_file": {"type": ["string", "null"]},
          "processed_file": {"type": ["string", "null"]},
          "hash_sha256": {"type": ["string", "null"]},
          "readiness_gate": {
            "enum": ["REVIEW", "BLOCK", "APPROVE_FOR_BACKTEST"]
          },
          "features_include_future_values": {"type": "boolean"},
          "target_uses_future_values": {"type": "boolean"},
          "comparability_status": {
            "enum": ["PASS", "REVIEW", "BLOCK"]
          },
          "notes": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
