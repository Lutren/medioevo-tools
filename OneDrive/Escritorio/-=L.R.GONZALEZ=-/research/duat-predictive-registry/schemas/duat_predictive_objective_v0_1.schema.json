{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "duat.predictive_objective.v0_1",
  "title": "DUAT Predictive Objective v0.1",
  "type": "object",
  "required": [
    "objective_id",
    "version",
    "status",
    "synthetic",
    "target_type",
    "prediction_task",
    "canonical_indicator_id",
    "data_policy",
    "inputs",
    "evaluation",
    "gates"
  ],
  "additionalProperties": true,
  "properties": {
    "objective_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "status": { "enum": ["internal_benchmark", "review", "blocked"] },
    "synthetic": { "type": "boolean" },
    "target_type": { "enum": ["numeric_time_series"] },
    "prediction_task": { "enum": ["one_step_ahead_forecast"] },
    "canonical_indicator_id": { "type": "string", "minLength": 1 },
    "data_policy": {
      "type": "object",
      "required": ["offline_only", "private_data", "external_api", "publication_gate"],
      "properties": {
        "offline_only": { "const": true },
        "private_data": { "const": false },
        "external_api": { "const": false },
        "publication_gate": { "const": "BLOCK" }
      }
    },
    "inputs": {
      "type": "object",
      "required": ["preferred_sources", "fixture_paths", "crosswalk_path"],
      "properties": {
        "preferred_sources": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "fixture_paths": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "crosswalk_path": { "type": "string", "minLength": 1 },
        "accepted_comparability_classes": {
          "type": "array",
          "items": {
            "enum": ["EXACT", "STRONG_PROXY", "WEAK_PROXY", "NOT_COMPARABLE", "REVIEW"]
          }
        }
      }
    },
    "evaluation": {
      "type": "object",
      "required": ["split", "baselines", "enhanced_methods", "metrics"],
      "properties": {
        "split": { "const": "TimeSeriesSplit" },
        "baselines": {
          "type": "array",
          "items": { "enum": ["last_value", "moving_average"] }
        },
        "enhanced_methods": {
          "type": "array",
          "items": { "type": "string" }
        },
        "metrics": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "gates": {
      "type": "object",
      "required": ["required", "stop_on_secret", "stop_on_private_data", "license_review_is_publication_block"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stop_on_secret": { "const": true },
        "stop_on_private_data": { "const": true },
        "license_review_is_publication_block": { "const": true }
      }
    }
  }
}
